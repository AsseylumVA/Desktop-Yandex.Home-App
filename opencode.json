{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--mount",
        "type=bind,src=${workspaceFolder},dst=/projects/workspace",
        "yandex-home-mcp/filesystem:latest",
        "/projects"
      ],
      "enabled": true,
      "description": "Filesystem operations — read/write files, create/list/delete dirs, search, metadata"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "mcp/sequentialthinking"
      ],
      "enabled": true,
      "description": "Structured step-by-step problem solving with revisions and branching"
    },
    "memories.sh": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-v",
        "${userHome}/.config/memories:/data",
        "yandex-home-mcp/memories:latest"
      ],
      "enabled": true,
      "description": "Persistent memory for coding agents — stores context, rules, and facts across sessions via SQLite"
    },
    "codegraph": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-v",
        "${workspaceFolder}:/workspace",
        "-w",
        "/workspace",
        "yandex-home-mcp/codegraph:latest"
      ],
      "enabled": true,
      "description": "Code knowledge graph — AST search, call graph, impact analysis, dependency graph, dead code detection"
    }
  },
  "instructions": ["AGENTS.md"]
}
